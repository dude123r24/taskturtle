{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm install @tailwindcss/oxide-linux-x64-gnu@4.2.2 @tailwindcss/oxide-linux-x64-musl@4.2.2 --no-save --no-audit --no-fund && npm run build"
    },
    "deploy": {
        "startCommand": "npx prisma migrate deploy && npm start",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}